{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TiyCode",
  "version": "0.1.0",
  "identifier": "ai.tiy.tiycode",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TiyCode",
        "width": 1280,
        "height": 820,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "center": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "additionalBrowserArgs": "--disable-background-timer-throttling --disable-backgrounding-occluded-windows",
        "windowEffects": {
          "effects": ["titlebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/256x256@2x.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Tiy AI",
    "homepage": "https://tiy.ai",
    "category": "Productivity",
    "createUpdaterArtifacts": true,
    "resources": [
      "bundled-catalog/catalog.json",
      "bundled-catalog/catalog.manifest.json"
    ],
    "shortDescription": "An AI-first desktop coding agent.",
    "longDescription": "TiyCode is an AI-first desktop coding agent built for a new coding collaboration paradigm, where humans work through conversation and agents drive execution in a real workspace.",
    "copyright": "© 2026 Tiy AI",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "mainBinaryName": "TiyCode",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3MTVGMjk0NkQ5MURGNzYKUldSMjM1RnRsUElWOXliUU5iMzBxeUFnTVM5YjgxQ3ZMbVU0OGp3aFZFYUFHMTZubFR4emVnbTQK",
      "endpoints": [
        "https://github.com/TiyAgents/tiycode/releases/latest/download/latest.json"
      ]
    }
  }
}
