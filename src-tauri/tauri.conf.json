{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TiyCode",
  "version": "0.1.0",
  "identifier": "ai.tiy.tiycode",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TiyCode",
        "width": 1280,
        "height": 820,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "center": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 20
        },
        "decorations": true,
        "transparent": false,
        "windowEffects": {
          "effects": [
            "titlebar"
          ],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Tiy AI",
    "homepage": "https://tiy.ai",
    "category": "Productivity",
    "externalBin": [
      "target/tiy-rg/rg"
    ],
    "shortDescription": "Open-source, flexible, convenient cross-platform vibe-coding agent.",
    "longDescription": "TiyCode is an open-source, flexible, convenient cross-platform vibe-coding agent built with Tauri, React, and TypeScript.",
    "copyright": "© 2026 Tiy AI",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "mainBinaryName": "TiyCode"
}
