{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tiy Agent",
  "version": "0.1.0",
  "identifier": "ai.tiy.agent",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tiy Agent",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 20
        },
        "decorations": true,
        "transparent": true,
        "windowEffects": {
          "effects": [
            "titlebar"
          ],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Tiy AI",
    "homepage": "https://tiy.ai",
    "category": "Productivity",
    "shortDescription": "Cross-platform desktop AI agent built with Tauri.",
    "longDescription": "Tiy Agent is a cross-platform desktop AI agent application built with Tauri, React and TypeScript.",
    "copyright": "© 2026 Tiy AI"
  }
}
